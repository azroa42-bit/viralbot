# ════════════════════════════════════════════════════════
# ViralBot — Environment Configuration
# Copy to .env and fill in your values.
# ════════════════════════════════════════════════════════

# ── Claude API (required) ────────────────────────────────
ANTHROPIC_API_KEY=your_key_here

# ── Reddit ───────────────────────────────────────────────
# reddit.com/prefs/apps → create "script" type app
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USERNAME=your_username
REDDIT_PASSWORD=your_password
REDDIT_USER_AGENT=ViralBot/1.0 by u/your_username
# Subreddits to post to. Start with r/test, then expand.
REDDIT_POST_SUBREDDITS=test

# ── YouTube ──────────────────────────────────────────────
# console.cloud.google.com → enable YouTube Data API v3
YOUTUBE_API_KEY=your_api_key
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json   # OAuth Desktop app JSON

# ── TikTok ───────────────────────────────────────────────
# developers.tiktok.com → create app → request Content Posting API
TIKTOK_CLIENT_KEY=your_client_key
TIKTOK_CLIENT_SECRET=your_client_secret
# Your TikTok Shop affiliate creator ID (from TikTok Shop partner platform)
TIKTOK_SHOP_AFFILIATE_ID=

# ── Amazon Associates (PA API) ───────────────────────────
# affiliate-program.amazon.com → PA API access granted after 3 sales
# Then: console.aws.amazon.com → create IAM user with PA API access
AMAZON_ACCESS_KEY=your_access_key
AMAZON_SECRET_KEY=your_secret_key
AMAZON_ASSOCIATE_TAG=yourtag-20
AMAZON_COUNTRY=US

# ── ClickBank ────────────────────────────────────────────
# clickbank.com → Settings → My Account → Edit Account → API Keys
CLICKBANK_DEV_KEY=your_dev_key
CLICKBANK_API_KEY=your_clerk_api_key
CLICKBANK_AFFILIATE_ID=your_cb_nickname

# ── Manual products (any network) ────────────────────────
# Add any affiliate product directly — no API needed.
# Format (fields separated by |, products by ||):
#   Name | Description | AffiliateURL | ImageURL | Price | Commission% | Category
# Example:
# MANUAL_PRODUCTS=Protein Powder|Top-rated whey protein with 25g protein per serving|https://amzn.to/xxx|https://images.amazon.com/xxx.jpg|49.99|4|health||VPN Software|Best VPN for privacy|https://vpn.com/affiliate/xxx||54.99|40|tech

MANUAL_PRODUCTS=

# ── Affiliate links (trend pipeline) ─────────────────────
# Appended to Reddit posts when topic matches keyword (case-insensitive)
# Format: keyword:url,keyword:url
AFFILIATE_LINKS=tech:https://amzn.to/YOUR_TECH_LINK,investing:https://amzn.to/YOUR_FINANCE_LINK

# ── Pipeline settings ─────────────────────────────────────
RUN_INTERVAL_HOURS=2       # Trend pipeline frequency
MAX_TRENDS_PER_RUN=3       # Trends per cycle
PRODUCT_INTERVAL_HOURS=6   # Product pipeline frequency
MAX_PRODUCTS_PER_RUN=3     # Products per cycle

# ── Paths ─────────────────────────────────────────────────
DB_PATH=viralbot.db
VIDEO_OUTPUT_DIR=videos
