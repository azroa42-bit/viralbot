# === Claude API (required for content generation) ===
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_key_here

# === Reddit (free — register at reddit.com/prefs/apps) ===
# Create a "script" type app
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=ViralBot/1.0 by u/your_reddit_username

# Which subreddits to POST to (comma-separated)
# Start with r/test until you're ready for real posts
REDDIT_POST_SUBREDDITS=test

# === YouTube (free — console.cloud.google.com) ===
# 1. Create a project, enable YouTube Data API v3
# 2. Create API Key (for reading trends)
# 3. Create OAuth 2.0 client ID (for uploading — type: Desktop app)
# 4. Download the client secrets JSON and set path below
YOUTUBE_API_KEY=your_api_key
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# === Pipeline settings ===
RUN_INTERVAL_HOURS=2         # How often to scan + post
MAX_TRENDS_PER_RUN=3         # Trends to process per cycle

# === Affiliate links (optional — appended when post topic matches keyword) ===
# Format: keyword:url,keyword:url   — keyword matched case-insensitively against post title
# Get Amazon affiliate links at: affiliate-program.amazon.com
# Get ClickBank links at: clickbank.com
AFFILIATE_LINKS=tech:https://amzn.to/YOUR_TECH_LINK,investing:https://amzn.to/YOUR_FINANCE_LINK

# === Paths ===
DB_PATH=viralbot.db
VIDEO_OUTPUT_DIR=videos
